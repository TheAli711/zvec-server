# Zvec Server configuration (all variables are optional; defaults shown).
# Copy to `.env` and adjust, or set as real environment variables.
# All variables use the ZVEC_SERVER_ prefix.

# --- Storage ---
# Root directory for all server data.
ZVEC_SERVER_DATA_DIR=./data
# Override the SQLite metadata DB path (default: <data_dir>/metadata.db).
# ZVEC_SERVER_METADATA_DB_PATH=./data/metadata.db
# Override the collections root directory (default: <data_dir>/collections).
# ZVEC_SERVER_COLLECTIONS_DIR=./data/collections

# --- HTTP server ---
ZVEC_SERVER_HOST=0.0.0.0
ZVEC_SERVER_PORT=8000

# --- Logging ---
# Level: DEBUG | INFO | WARNING | ERROR
ZVEC_SERVER_LOG_LEVEL=INFO
# Format: json | console
ZVEC_SERVER_LOG_FORMAT=json

# --- Zvec engine ---
# Enable memory-mapped storage for collections.
ZVEC_SERVER_ENABLE_MMAP=true
# Soft memory cap for the Zvec engine in MB (default: auto-detect from cgroup).
# ZVEC_SERVER_ZVEC_MEMORY_LIMIT_MB=2048
# Query / optimize thread counts (default: auto-detect from CPU).
# ZVEC_SERVER_ZVEC_QUERY_THREADS=4
# ZVEC_SERVER_ZVEC_OPTIMIZE_THREADS=2

# --- Authentication ---
# Off by default. When enabled, every request except /healthz and /readyz must
# send an `Authorization: Bearer <api_key>` header. The key is read from the
# environment (or your secret manager) and never persisted by the server.
ZVEC_SERVER_AUTH_ENABLED=false
# Required (non-empty) when ZVEC_SERVER_AUTH_ENABLED=true. Use a long random
# value, e.g. `openssl rand -hex 32`.
# ZVEC_SERVER_API_KEY=change-me
